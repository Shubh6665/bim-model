# NextAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# MongoDB (required for Email/Magic Link auth adapter)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=bim-client

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_full_gmail_address@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=your_full_gmail_address@gmail.com

# Autodesk Forge API Credentials
FORGE_CLIENT_ID=your_forge_client_id
FORGE_CLIENT_SECRET=your_forge_client_secret
FORGE_BUCKET_KEY=your_bucket_key
FORGE_REGION=us

# Google Maps API Configuration
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key 

# UbiBot IoT Platform Integration
# Get your account key from: https://console.ubibot.com -> Account -> Profile Settings
UBIBOT_ACCOUNT_KEY=your_ubibot_account_key

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_full_gmail_address@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="Your Name your_full_gmail_address@gmail.com"
APP_BASE_URL=http://localhost:3000
